{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Document Generator",
    "description": "Collection v2.4 — Couverture API + métriques worker (:9464). Alignée sur docs/openapi.yaml. Après « Create batch (userIds) », les variables batchId / documentId alimentent Get batch / Get PDF.\n\nCourbes benchmark : benchmark-series-excel-fr-avecgraph.xlsx à la racine du dépôt.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "workerMetricsUrl", "value": "http://localhost:9464" },
    { "key": "batchId", "value": "" },
    { "key": "documentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'x-correlation-id', value: pm.variables.replaceIn('{{$guid}}') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 ou 503', function () {",
              "  pm.expect([200, 503]).to.include(pm.response.code);",
              "});",
              "pm.test('Corps JSON', function () {",
              "  pm.response.to.be.json;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/metrics"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('baseUrl')) {",
              "  pm.collectionVariables.set('baseUrl', 'http://localhost:3000');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Corps non vide', function () {",
              "  pm.expect(pm.response.text().length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Metrics (worker)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{workerMetricsUrl}}/metrics"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('workerMetricsUrl')) {",
              "  pm.collectionVariables.set('workerMetricsUrl', 'http://localhost:9464');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const text = pm.response.text();",
              "pm.test('Corps non vide', function () {",
              "  pm.expect(text.length).to.be.above(0);",
              "});",
              "pm.test('Séries sujet présentes (noms métriques)', function () {",
              "  pm.expect(text).to.include('documents_generated_total');",
              "  pm.expect(text).to.include('batch_processing_duration_seconds');",
              "  pm.expect(text).to.include('queue_size');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create batch — userIds vide (400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userIds\": []\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/documents/batch"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'x-correlation-id', value: pm.variables.replaceIn('{{$guid}}') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 (validation)', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Code erreur VALIDATION_ERROR', function () {",
              "  pm.expect(j).to.have.property('error');",
              "  pm.expect(j.error.code).to.eql('VALIDATION_ERROR');",
              "});",
              "pm.test('Message de validation non vide', function () {",
              "  pm.expect(j.error.message).to.be.a('string');",
              "  pm.expect(j.error.message.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create batch (userIds)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userIds\": [\"user-demo-postman-1\"]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/documents/batch"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('batchId', '');",
              "pm.collectionVariables.set('documentId', '');",
              "pm.request.headers.upsert({ key: 'x-correlation-id', value: pm.variables.replaceIn('{{$guid}}') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 202', function () {",
              "  pm.response.to.have.status(202);",
              "});",
              "const j = pm.response.json();",
              "pm.test('batchId et documentIds', function () {",
              "  pm.expect(j.batchId).to.be.a('string');",
              "  pm.expect(j.documentIds).to.be.an('array').that.is.not.empty;",
              "});",
              "if (pm.response.code === 202 && j.batchId && j.documentIds && j.documentIds[0]) {",
              "  pm.collectionVariables.set('batchId', j.batchId);",
              "  pm.collectionVariables.set('documentId', j.documentIds[0]);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get batch",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/documents/batch/{{batchId}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('batchId');",
              "if (!id) { console.warn('Exécuter d’abord Create batch (userIds) pour définir batchId'); }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 ou 404', function () {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get document PDF",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/documents/{{documentId}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('documentId');",
              "if (!id) { console.warn('Exécuter d’abord Create batch (userIds) pour définir documentId'); }"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status attendu (200 PDF, 409 en cours, 404 sinon)', function () {",
              "  pm.expect([200, 404, 409]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get document — documentId invalide (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/documents/ce-n-est-pas-un-objectid-mongo"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'x-correlation-id', value: pm.variables.replaceIn('{{$guid}}') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 (document introuvable / id invalide)', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Code erreur NOT_FOUND', function () {",
              "  pm.expect(j.error.code).to.eql('NOT_FOUND');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get batch — batchId invalide (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/documents/batch/id-invalide-pas-24hex"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'x-correlation-id', value: pm.variables.replaceIn('{{$guid}}') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Code erreur NOT_FOUND', function () {",
              "  pm.expect(j.error.code).to.eql('NOT_FOUND');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
