PORT=3000
NODE_ENV=development
LOG_LEVEL=info
MONGODB_URI=mongodb://localhost:27017/document-generator
# Préférer 127.0.0.1 si localhost résout en IPv6 et Redis Docker n’écoute que IPv4
REDIS_URL=redis://127.0.0.1:6379
# redis | memory — memory = file en RAM dans le processus serveur (worker intégré, sans worker-entry)
# QUEUE_BACKEND=memory
BULL_QUEUE_NAME=document-pdf
PDF_WORKER_CONCURRENCY=2
# Pool de threads PDF réutilisables (défaut = PDF_WORKER_CONCURRENCY si omis)
# PDF_THREAD_POOL_SIZE=2
GRIDFS_BUCKET_NAME=pdfs
CIRCUIT_TIMEOUT_MS=10000
CIRCUIT_ERROR_THRESHOLD_PERCENTAGE=50
CIRCUIT_RESET_TIMEOUT_MS=30000
CIRCUIT_VOLUME_THRESHOLD=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
BATCH_MAX_DOCUMENTS=1000
JSON_BODY_LIMIT_MB=32
# Port HTTP /metrics sur le processus worker (0 = désactivé). API : voir GET /metrics sur PORT.
WORKER_METRICS_PORT=9464
QUEUE_METRICS_POLL_MS=10000
# PDF_GENERATION_TIMEOUT_MS=5000
# GRACEFUL_SHUTDOWN_ACTIVE_JOBS_TIMEOUT_MS=120000
# DOCUSIGN_SIM_FAILURE_RATE=0.02
